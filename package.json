{
  "name": "integration-core",
  "author": "Warren Hennemuth",
  "keywords": [
    "integration",
    "cdc",
    "typescript",
    "javascript"
  ],
  "license": "ISC",
  "description": "A nodejs typescript library of abstract components and interfaces that provide baseline functionality for CDC operations between source and target systems.",
  "repository": {
    "type": "git",
    "url": "https://github.com/whennemuth/integration-core.git"
  },
  "version": "1.0.0",
  "module": "dist/esm/index.js",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist/ && node bin/build.js",
    "build:tsc": "rm -rf dist/ && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": "tsc --module CommonJS --outdir dist/cjs",
    "pack": "npm run build && npm pack --pack-destination .",
    "publish": "npm run pack && npm publish ./integration-core-1.0.0.tgz",
    "watch": "tsc -w",
    "test": "jest --silent"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "esbuild": "^0.25.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
